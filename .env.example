# ===========================================
# Pulse Environment Variables
# ===========================================

# Supabase (cloud)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Node local DB
POSTGRES_USER=pulse
POSTGRES_PASSWORD=
POSTGRES_DB=pulse_node
DATABASE_URL=postgresql://pulse:password@localhost:5432/pulse_node

# Jellyfin
JELLYFIN_BASE_URL=http://jellyfin:8096
JELLYFIN_API_KEY=

# Node identity (set during registration)
NODE_ID=
NODE_REGISTRATION_TOKEN=
CLOUD_API_URL=

# Auth
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000
